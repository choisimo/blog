# =============================================================================
# GitHub Actions Secrets - CI / Worker 배포용
# =============================================================================
# 이 파일은 GitHub Actions 워크플로우에서 사용하는 secrets 템플릿입니다.
# 백엔드 인프라(DB, SSH, 모니터링 등)는 .env.backend에서 별도 관리합니다.
#
# 사용법:
#   1. 복사: cp .gh_env .gh_env.local
#   2. 실제 값 입력 후 GitHub CLI로 등록:
#      grep -v '^#' .gh_env.local | grep -v '^$' | while IFS='=' read -r key value; do
#        gh secret set "$key" --body "$value"
#      done
#
# =============================================================================

# -----------------------------------------------------------------------------
# [REQUIRED] Frontend Build (deploy.yml, build-extra-images.yml)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=https://api.nodove.com
VITE_TERMINAL_GATEWAY_URL=wss://terminal.nodove.com

# -----------------------------------------------------------------------------
# [OPTIONAL] Frontend Features
# -----------------------------------------------------------------------------
VITE_CHAT_BASE_URL=
VITE_CHAT_API_KEY=
VITE_FEATURE_FAB=true

# -----------------------------------------------------------------------------
# [Workers] Shared worker deployment secrets
# sync-workers-secrets.yml / worker control plane / deploy contracts
# -----------------------------------------------------------------------------
BACKEND_ORIGIN=https://blog-b.nodove.com
BACKEND_KEY=
JWT_SECRET=
INTERNAL_KEY=
TERMINAL_SESSION_SECRET=

# -----------------------------------------------------------------------------
# [Workers] Optional control-plane and OAuth secrets
# -----------------------------------------------------------------------------
ADMIN_ALLOWED_EMAILS=
ADMIN_SETUP_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=https://noblog.nodove.com
CF_ACCESS_AUD=
CF_TEAM_DOMAIN=

# -----------------------------------------------------------------------------
# [Workers] AI / public runtime configuration secrets
# -----------------------------------------------------------------------------
AI_DEFAULT_MODEL=gpt-5.2
AI_VISION_MODEL=gpt-4o
PERPLEXITY_MODEL=sonar
API_BASE_URL=https://api.nodove.com
ASSETS_BASE_URL=https://noblog.nodove.com/images
ALLOWED_ORIGINS=https://noblog.nodove.com
